# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
env/

# ── Logs ──
*.log
crash.log
k2_crash.log*

# ── PyInstaller / installer build outputs (regenerated, huge) ──
build/
dist/
installer_output/
build_pyinstaller.log

# ── Run artifacts / large outputs (255MB+, regenerated) ──
cfd_run/
cfd_run_euler/
fem_run/
fem_test_run/
*.msh
*.vtu
*.vtk
*.cgns
*.dat

# ── Bundled third-party binaries (69MB SU2 build) ──
# Ignore bin/ contents but keep the app icon assets tracked (negation only
# works when the directory itself isn't excluded, hence bin/* not bin/).
bin/*
!bin/k2.ico
!bin/k2_icon.png

# ── Vendored upstream repo (keep out of history) ──
scratch/openMotor_repo/

# ── Editor / tooling ──
.claude/
.vscode/
.idea/
*.swp
.DS_Store

# ── Scratch experiments ──
scratch/
data/thrust_curves/
